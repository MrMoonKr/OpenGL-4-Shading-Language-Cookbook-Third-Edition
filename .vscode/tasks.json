        "--target",
        "ch00_glew"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "cmake: configure debug",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cmake: build debug ch00_app",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "build-debug",
        "--target",
        "ch00_app"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "cmake: configure debug",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cmake: build debug ch01",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "build-debug",
        "--target",
        "ch01"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "cmake: configure debug",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cmake: configure release",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "vs2022-release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
